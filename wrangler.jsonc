{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "soda-backyard-garden",
  "main": "./worker.js",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB"
    }
  ]
}
